# Server
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017

# JWT
ACCESS_TOKEN_SECRET=replace_with_long_random_string
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=replace_with_long_random_string
REFRESH_TOKEN_EXPIRY=7d
TEMP_TOKEN_SECRET=replace_with_long_random_string
TEMP_TOKEN_EXPIRY=15m

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Event Management <no-reply@eventmgmt.local>"

# App
CLIENT_URL=http://localhost:5173
